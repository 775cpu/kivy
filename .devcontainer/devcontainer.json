{
    "name": "Kivy Android Builder",
    "image": "ghcr.io/kivy/buildozer:latest",
    "remoteUser": "user",
    "mounts": [
        "source=kivy-android-sdk-cache,target=/home/user/.buildozer,type=volume"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}